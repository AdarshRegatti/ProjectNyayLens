{
  "builds": [
    {
      "src": "src/api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "src/api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "web/$1"
    }
  ]
}
