# Environment Variables for NyayLens
# Copy this file to .env and fill in your values
# Never commit the .env file to version control

# ── Required ──────────────────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=GROQ_API_KEY=your_groq_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────
# Override default model (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant

# Path to your FAISS index (default: outputs/retrieval/faiss_index)
# FAISS_INDEX_PATH=outputs/retrieval/faiss_index

# Path to your SQLite database (default: outputs/retrieval/judgments.db)
# DB_PATH=outputs/retrieval/judgments.db
